# ═══════════════════════════════════════════
# 面霸 AI 面试教练 - 配置文件
# ═══════════════════════════════════════════

# ── 选择 LLM 提供商 ──
# 可选: deepseek / openai / gemini / qwen / zhipu / moonshot / siliconflow / custom
LLM_PROVIDER=deepseek

# ── 各提供商 API Key（配哪个填哪个） ──
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
SILICONFLOW_API_KEY=

# ── 自定义 Provider（OpenAI 兼容 API） ──
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL_NAME=

# ── LLM 通用参数 ──
# 留空则使用 Provider 的默认模型
LLM_MODEL_NAME=
LLM_TEMPERATURE=0.7

# ── 语音模型（阿里云 DashScope） ──
VOICE_API_KEY=
VOICE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VOICE_MODEL_NAME=qwen3-omni-flash
VOICE_NAME=Chelsie

# ── RAG ──
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
QUESTION_BANK_PATH=./core/data/question_bank.json

# ── 文件 ──
UPLOAD_DIR=./data/uploads
